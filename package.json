{
  "name": "bang-search",
  "type": "module",
  "version": "1.7.1",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "main": "dist/server/entry.mjs",
  "scripts": {
    "check": "concurrently -c auto \"pnpm:lint:*\" \"pnpm:build\"",
    "lint:astro": "astro check",
    "lint:prettier": "prettier --check .",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "node .husky/install.js || true",
    "test": "playwright test",
    "bangs:update": "curl https://raw.githubusercontent.com/kagisearch/bangs/refs/heads/main/data/bangs.json | jq 'sort_by(.t) | map([[.t] + (.ts // []), .u])' > src/bangs.json"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/node": "10.1.4",
    "@fontsource-variable/inter": "5.2.8",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.1",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vite-pwa/astro": "1.2.0",
    "astro": "6.4.8",
    "concurrently": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.1",
    "vite-plugin-pwa": "1.3.0",
    "workbox-precaching": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "lint-staged": {
    "*.{js,mjs,ts,astro,css,md,json,yml}": "prettier --write"
  }
}
